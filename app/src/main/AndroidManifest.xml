<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================
         PERMISSIONS
         ============================================ -->
    <!-- Network & Internet -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Location Services (for job location features) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Notifications & Alerts -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo_hunter"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo_hunter"
        android:supportsRtl="false"
        android:theme="@style/AppTheme"
        tools:targetApi="31">

        <!-- ============================================
             SPLASH & ONBOARDING
             ============================================ -->
        <!-- Splash Screen (Entry Point) -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/AppTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding (first launch) -->
        <activity
            android:name=".activities.OnboardingActivity"
            android:exported="false"
            android:theme="@style/AppTheme" />

        <!-- ============================================
             AUTHENTICATION
             ============================================ -->
        <!-- Login Screen -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:windowSoftInputMode="adjustResize" />

        <!-- ============================================
             MAIN APPLICATION
             ============================================ -->
        <!-- Main Dashboard -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:launchMode="singleTop" />

        <!-- ============================================
             JOB MANAGEMENT
             ============================================ -->
        <!-- Job List View -->
        <activity
            android:name=".activities.JobListActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Add New Job -->
        <activity
            android:name=".activities.AddJobActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".activities.JobListActivity" />

        <!-- Edit Existing Job -->
        <activity
            android:name=".activities.EditJobActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".activities.JobDetailsActivity" />

        <!-- Job Details View -->
        <activity
            android:name=".activities.JobDetailsActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:parentActivityName=".activities.JobListActivity" />

        <!-- Favorites -->
        <activity
            android:name=".activities.FavoritesActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:parentActivityName=".activities.MainActivity" />

        <!-- ============================================
             SPEED APPLY FEATURE
             ============================================ -->
        <!-- Quick Job Application (Deep Links) -->
        <activity
            android:name=".activities.SpeedApplyActivity"
            android:exported="true"
            android:theme="@style/AppTheme"
            android:windowSoftInputMode="adjustResize">

            <!-- Share Intent Filter (for sharing job links) -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

            <!-- Deep Link Verification (Job Sites) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <!-- LinkedIn Job Links -->
                <data
                    android:scheme="https"
                    android:host="linkedin.com"
                    android:pathPattern="/jobs.*" />
                <data
                    android:scheme="https"
                    android:host="www.linkedin.com"
                    android:pathPattern="/jobs.*" />

                <!-- Indeed Job Links -->
                <data
                    android:scheme="https"
                    android:host="indeed.com" />
                <data
                    android:scheme="https"
                    android:host="www.indeed.com" />

                <!-- Israeli Job Sites -->
                <data
                    android:scheme="https"
                    android:host="drushim.co.il" />
                <data
                    android:scheme="https"
                    android:host="www.drushim.co.il" />
                <data
                    android:scheme="https"
                    android:host="alljobs.co.il" />
                <data
                    android:scheme="https"
                    android:host="www.alljobs.co.il" />
            </intent-filter>
        </activity>

        <!-- ============================================
             CV MANAGER
             ============================================ -->
        <!-- CV Management Screen -->
        <activity
            android:name=".activities.CVManagerActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:parentActivityName=".activities.MainActivity" />

        <!-- ============================================
             INTERVIEWS
             ============================================ -->
        <!-- Interview List -->
        <activity
            android:name=".activities.InterviewsActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Add New Interview -->
        <activity
            android:name=".activities.AddInterviewActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".activities.InterviewsActivity" />

        <!-- ============================================
             COMMUNITY
             ============================================ -->
        <!-- Community Questions & Tips -->
        <activity
            android:name=".activities.CommunityActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Add Community Question -->
        <activity
            android:name=".activities.AddQuestionActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".activities.CommunityActivity" />

        <!-- ============================================
             STATISTICS
             ============================================ -->
        <!-- Application Statistics Dashboard -->
        <activity
            android:name=".activities.StatisticsActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:parentActivityName=".activities.MainActivity" />

        <!-- ============================================
             SETTINGS & PROFILE
             ============================================ -->
        <!-- User Profile -->
        <activity
            android:name=".activities.ProfileActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:parentActivityName=".activities.MainActivity" />

        <!-- App Settings -->
        <activity
            android:name=".activities.SettingsActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:parentActivityName=".activities.MainActivity" />

        <!-- About Screen -->
        <activity
            android:name=".activities.AboutActivity"
            android:exported="false"
            android:theme="@style/AppTheme"
            android:parentActivityName=".activities.MainActivity" />

        <!-- ============================================
             RECEIVERS
             ============================================ -->
        <receiver
            android:name=".receivers.InterviewReminderReceiver"
            android:exported="false" />

    </application>

</manifest>
