<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted glass blur effect with layered white translucency -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- שכבה ראשונה: רקע לבן חזק -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#D9FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- שכבה שנייה: גרדיאנט עדין מעל -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#E6FFFFFF"
                android:centerColor="#CCFFFFFF"
                android:endColor="#B3FFFFFF"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- שכבה שלישית: מסגרת לבנה -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1.5dp"
                android:color="#E6FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>

</layer-list>
