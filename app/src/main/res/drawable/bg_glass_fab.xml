<?xml version="1.0" encoding="utf-8"?>
<!-- Glass-style FAB with purple gradient and white border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background gradient with transparency -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#E6667EEA"
                android:centerColor="#E6764BA2"
                android:endColor="#E6F093FB"
                android:type="linear" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Glass border effect -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="2dp"
                android:color="#80FFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</layer-list>
