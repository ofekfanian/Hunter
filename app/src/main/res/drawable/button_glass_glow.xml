<?xml version="1.0" encoding="utf-8"?>
<!-- Glowing glass-style button with blue border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow - קו כחול דק -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#6A9FDB" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    
    <!-- Inner Button - רקע כחול כהה -->
    <item
        android:left="2dp"
        android:right="2dp"
        android:top="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#3B5A8A" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>
