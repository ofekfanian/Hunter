<?xml version="1.0" encoding="utf-8"?>
<!-- Decorative Background with Gradient and Logo Overlays -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Gradient Background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_dark_purple" />

    <!-- Decorative Logo (Top Right) -->
    <ImageView
        android:id="@+id/background_IMG_top"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-60dp"
        android:alpha="0.14"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:src="@drawable/logo_hunter_line_art" />

    <!-- Decorative Logo (Bottom Left) -->
    <ImageView
        android:id="@+id/background_IMG_bottom"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-50dp"
        android:layout_marginBottom="-60dp"
        android:alpha="0.14"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:src="@drawable/logo_hunter_line_art" />

</FrameLayout>
