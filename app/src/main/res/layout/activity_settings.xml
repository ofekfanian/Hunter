<?xml version="1.0" encoding="utf-8"?>
<!-- Settings — profile card, preferences (notifications), about, demo data, logout -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settings_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.SettingsActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include layout="@layout/background_decorative" />

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <include layout="@layout/common_header" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="100dp"
                android:clipToPadding="false"
                android:paddingBottom="130dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- ════════════════════════════════
                         PROFILE CARD
                         ════════════════════════════════ -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/settings_card_profile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/glass_background"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/primary_purple"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/gradient_stat_applied"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="20dp"
                            android:paddingVertical="20dp">

                            <FrameLayout
                                android:layout_width="52dp"
                                android:layout_height="52dp">

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/circle_glass" />

                                <ImageView
                                    android:id="@+id/profile_image"
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/app_name"
                                    android:src="@drawable/ic_person"
                                    app:tint="@color/white" />

                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/profile_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:text="@string/default_user_name"
                                    android:textColor="@color/white"
                                    android:textSize="18sp"
                                    tools:text="John Doe" />

                                <TextView
                                    android:id="@+id/profile_subtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:alpha="0.75"
                                    android:fontFamily="@font/montserrat_medium"
                                    android:text="@string/no_email"
                                    android:textColor="@color/white"
                                    android:textSize="12sp"
                                    tools:text="john@example.com" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:alpha="0.5"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/white" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- ════════════════════════════════
                         PREFERENCES
                         ════════════════════════════════ -->
                    <TextView
                        style="@style/SectionTitle"
                        android:shadowColor="@color/primary_purple"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="10"
                        android:text="@string/settings_preferences" />

                    <!-- Notifications Toggle -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:cardBackgroundColor="@color/glass_background"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/purple_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:contentDescription="@string/settings_notifications"
                                android:src="@drawable/ic_notifications"
                                app:tint="@color/primary_purple" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/montserrat_semibold"
                                android:text="@string/settings_notifications"
                                android:textColor="@color/white"
                                android:textSize="14sp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/settings_switch_notifications"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                app:thumbTint="@color/white"
                                app:trackTint="@color/primary_purple" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- ════════════════════════════════
                         MORE
                         ════════════════════════════════ -->
                    <TextView
                        style="@style/SectionTitle"
                        android:shadowColor="@color/primary_purple"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="10"
                        android:text="@string/settings_more" />

                    <!-- About -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/settings_card_about"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/glass_background"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/purple_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:contentDescription="@string/settings_about"
                                android:src="@drawable/ic_info"
                                app:tint="@color/primary_purple" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/montserrat_semibold"
                                    android:text="@string/settings_about"
                                    android:textColor="@color/white"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:alpha="0.55"
                                    android:fontFamily="@font/montserrat_medium"
                                    android:text="@string/settings_about_description"
                                    android:textColor="@color/white"
                                    android:textSize="11sp" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:alpha="0.4"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/white" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Load Demo Data -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/settings_card_demo_data"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/glass_background"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/purple_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:contentDescription="@string/settings_demo_data"
                                android:src="@drawable/ic_database"
                                app:tint="@color/primary_purple" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/montserrat_semibold"
                                    android:text="@string/settings_demo_data"
                                    android:textColor="@color/white"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:alpha="0.55"
                                    android:fontFamily="@font/montserrat_medium"
                                    android:text="@string/settings_demo_data_desc"
                                    android:textColor="@color/white"
                                    android:textSize="11sp" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:alpha="0.4"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/white" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Logout -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/settings_card_btn_logout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/glass_background"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/error_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="16dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/settings_logout"
                                android:src="@drawable/ic_logout"
                                app:tint="@color/error" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:fontFamily="@font/montserrat_semibold"
                                android:text="@string/settings_logout"
                                android:textColor="@color/error"
                                android:textSize="14sp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

            <include layout="@layout/bottom_navigation" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

    </FrameLayout>

    <include
        layout="@layout/drawer_menu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
