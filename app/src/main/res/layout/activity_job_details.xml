<?xml version="1.0" encoding="utf-8"?>
<!-- Job Details — hero card, URL, CV version, notes, share/delete actions -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.JobDetailsActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_dark_purple">

        <include layout="@layout/common_header" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="100dp"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Hero Profile Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/job_hero_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="@color/glass_background"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/accent_indigo"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/gradient_card_indigo"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="32dp">

                        <ImageView
                            android:id="@+id/profile_image"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginBottom="16dp"
                            android:src="@drawable/ic_business"
                            app:tint="@color/white"
                            android:alpha="0.9"
                            android:contentDescription="@string/app_name" />

                        <TextView
                            android:id="@+id/profile_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            tools:text="Google" />

                        <TextView
                            android:id="@+id/profile_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:alpha="0.85"
                            android:fontFamily="@font/montserrat_regular"
                            android:gravity="center"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            tools:text="Software Engineer" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Job Information Section -->
                <TextView
                    style="@style/SectionTitle"
                    android:text="@string/job_details_title"
                    android:shadowColor="@color/accent_indigo"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/glass_background"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/accent_indigo"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Location Row -->
                        <LinearLayout
                            android:id="@+id/detail_location_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="12dp"
                                android:src="@drawable/ic_location"
                                app:tint="@color/accent_indigo_light"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/hint_location"
                                android:textColor="@color/white"
                                android:alpha="0.6"
                                android:fontFamily="@font/montserrat_medium"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/detail_location"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:fontFamily="@font/montserrat_semibold"
                                android:textSize="14sp"
                                tools:text="Tel Aviv" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/drawer_divider" />

                        <!-- Status Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="12dp"
                                android:src="@drawable/ic_trending_up"
                                app:tint="@color/accent_indigo_light"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/job_status"
                                android:textColor="@color/white"
                                android:alpha="0.6"
                                android:fontFamily="@font/montserrat_medium"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/detail_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:fontFamily="@font/montserrat_semibold"
                                android:textSize="14sp"
                                tools:text="Applied" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/drawer_divider" />

                        <!-- Salary Row -->
                        <LinearLayout
                            android:id="@+id/detail_salary_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="12dp"
                                android:src="@drawable/ic_work"
                                app:tint="@color/accent_indigo_light"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/hint_salary"
                                android:textColor="@color/white"
                                android:alpha="0.6"
                                android:fontFamily="@font/montserrat_medium"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/detail_salary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/accent_green"
                                android:fontFamily="@font/montserrat_bold"
                                android:textSize="14sp"
                                tools:text="$120K" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/drawer_divider" />

                        <!-- Date Applied Row -->
                        <LinearLayout
                            android:id="@+id/detail_date_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="12dp"
                                android:src="@drawable/ic_calendar"
                                app:tint="@color/accent_indigo_light"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/hint_date"
                                android:textColor="@color/white"
                                android:alpha="0.6"
                                android:fontFamily="@font/montserrat_medium"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/detail_date"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:fontFamily="@font/montserrat_semibold"
                                android:textSize="14sp"
                                tools:text="15/03/2026" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/drawer_divider" />

                        <!-- Source Row -->
                        <LinearLayout
                            android:id="@+id/detail_source_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="12dp"
                                android:src="@drawable/ic_search"
                                app:tint="@color/accent_indigo_light"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/job_source"
                                android:textColor="@color/white"
                                android:alpha="0.6"
                                android:fontFamily="@font/montserrat_medium"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/detail_source"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:fontFamily="@font/montserrat_semibold"
                                android:textSize="14sp"
                                tools:text="LinkedIn" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/drawer_divider" />

                        <!-- Work Model Row -->
                        <LinearLayout
                            android:id="@+id/detail_work_model_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="12dp"
                                android:src="@drawable/ic_home"
                                app:tint="@color/accent_indigo_light"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/hint_work_model"
                                android:textColor="@color/white"
                                android:alpha="0.6"
                                android:fontFamily="@font/montserrat_medium"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/detail_work_model"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:fontFamily="@font/montserrat_semibold"
                                android:textSize="14sp"
                                tools:text="Hybrid" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/drawer_divider" />

                        <!-- Contact Row -->
                        <LinearLayout
                            android:id="@+id/detail_contact_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="12dp"
                                android:src="@drawable/ic_person"
                                app:tint="@color/accent_indigo_light"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/contact_person"
                                android:textColor="@color/white"
                                android:alpha="0.6"
                                android:fontFamily="@font/montserrat_medium"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/detail_contact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:fontFamily="@font/montserrat_semibold"
                                android:textSize="14sp"
                                tools:text="John Smith" />
                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Source URL Section -->
                <TextView
                    android:id="@+id/section_url"
                    style="@style/SectionTitle"
                    android:text="@string/source_url"
                    android:shadowColor="@color/accent_indigo"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/glass_background"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/accent_indigo"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/ic_link"
                            app:tint="@color/accent_indigo_light"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/card_text_url"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:alpha="0.9"
                            android:fontFamily="@font/montserrat_regular"
                            android:lineSpacingExtra="4dp"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            tools:text="https://careers.google.com/jobs/123" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- CV Version Section -->
                <TextView
                    android:id="@+id/section_cv"
                    style="@style/SectionTitle"
                    android:text="@string/cv_version"
                    android:shadowColor="@color/accent_indigo"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_cv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/glass_background"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/accent_indigo"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="12dp"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_description"
                            app:tint="@color/accent_indigo_light" />

                        <TextView
                            android:id="@+id/card_text_cv"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:alpha="0.9"
                            android:fontFamily="@font/montserrat_regular"
                            android:lineSpacingExtra="4dp"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            tools:text="CV v2.0 - Google" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Notes Section -->
                <TextView
                    android:id="@+id/section_notes"
                    style="@style/SectionTitle"
                    android:text="@string/notes"
                    android:shadowColor="@color/accent_indigo"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="@color/glass_background"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/accent_indigo"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/ic_note"
                            app:tint="@color/accent_indigo_light"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/card_text_notes"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:alpha="0.9"
                            android:fontFamily="@font/montserrat_regular"
                            android:lineSpacingExtra="4dp"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            tools:text="Great opportunity, applied through referral" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <!-- Share Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btn_share_feature"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/glass_background"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:strokeColor="@color/accent_indigo"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/gradient_card_indigo"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/feature_icon_share"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginBottom="8dp"
                                android:src="@drawable/ic_share"
                                app:tint="@color/white"
                                android:alpha="0.9"
                                android:contentDescription="@string/job_details_share" />

                            <TextView
                                android:id="@+id/feature_text_share"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_semibold"
                                android:text="@string/job_details_share"
                                android:textColor="@color/white"
                                android:textSize="14sp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Delete Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btn_delete_feature"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/glass_background"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:strokeColor="@color/delete_red"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/gradient_red"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/feature_icon_delete"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginBottom="8dp"
                                android:src="@drawable/ic_delete"
                                app:tint="@color/white"
                                android:alpha="0.9"
                                android:contentDescription="@string/job_details_delete" />

                            <TextView
                                android:id="@+id/feature_text_delete"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_semibold"
                                android:text="@string/job_details_delete"
                                android:textColor="@color/white"
                                android:textSize="14sp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <include
        layout="@layout/drawer_menu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
