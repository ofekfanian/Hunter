<?xml version="1.0" encoding="utf-8"?>
<!-- Edit Job form — update company, position, status, salary, notes -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.EditJobActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_dark_purple">

        <include layout="@layout/common_header" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/edit_job_form"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="100dp"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Basic Info -->
                <TextView
                    style="@style/SectionTitle"
                    android:text="@string/basic_information"
                    android:shadowColor="@color/accent_indigo_light"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10"
                    />

                <com.google.android.material.card.MaterialCardView
                    style="@style/GlassCard"
                    android:layout_marginBottom="20dp"
                    app:strokeColor="@color/accent_indigo_light"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:baselineAligned="false">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/company_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_work"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/company_text"
                                android:hint="@string/hint_company" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/position_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_work"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/position_text"
                                android:hint="@string/hint_position" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/location_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_location"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/location_text"
                                android:hint="@string/hint_location" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Job Details -->
                <TextView
                    style="@style/SectionTitle"
                    android:text="@string/job_details"
                    android:shadowColor="@color/accent_indigo_light"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10"
                    />

                <com.google.android.material.card.MaterialCardView
                    style="@style/GlassCard"
                    android:layout_marginBottom="20dp"
                    app:strokeColor="@color/accent_indigo_light"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:baselineAligned="false">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/salary_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_work"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/salary_text"
                                android:inputType="number"
                                android:hint="@string/hint_salary" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/job_url_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_link"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/job_url_text"
                                android:hint="@string/hint_job_url" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/contact_name_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_person"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/contact_name_text"
                                android:hint="@string/hint_contact_name" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/montserrat_semibold"
                            android:text="@string/job_source"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <Spinner
                            android:id="@+id/edit_job_spinner_source"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:fontFamily="@font/montserrat_regular"
                            android:padding="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/montserrat_semibold"
                            android:text="@string/hint_work_model"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <Spinner
                            android:id="@+id/edit_job_spinner_work_model"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:fontFamily="@font/montserrat_regular"
                            android:padding="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/montserrat_semibold"
                            android:text="@string/application_status"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <Spinner
                            android:id="@+id/edit_job_spinner_status"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:fontFamily="@font/montserrat_regular"
                            android:padding="16dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Additional Info -->
                <TextView
                    style="@style/SectionTitle"
                    android:text="@string/additional_details"
                    android:shadowColor="@color/accent_indigo_light"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10"
                    />

                <com.google.android.material.card.MaterialCardView
                    style="@style/GlassCard.LargeMargin"
                    app:strokeColor="@color/accent_indigo_light"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:baselineAligned="false">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/cv_version_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_work"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/cv_version_text"
                                android:hint="@string/hint_cv_version" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/notes_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_edit"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/notes_text"
                                android:hint="@string/hint_notes"
                                android:minLines="3"
                                android:inputType="textMultiLine" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/edit_job_BTN_cancel"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/gradient_red"
                        android:fontFamily="@font/montserrat_semibold"
                        android:text="@string/cancel"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:stateListAnimator="@null"
                        app:backgroundTint="@null"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_close"
                        app:iconGravity="textStart"
                        app:iconTint="@color/white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/edit_job_BTN_save"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/button_gradient_premium"
                        android:fontFamily="@font/montserrat_semibold"
                        android:text="@string/save"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:stateListAnimator="@null"
                        app:backgroundTint="@null"
                        app:cornerRadius="24dp"
                        app:icon="@drawable/ic_save"
                        app:iconGravity="textStart"
                        app:iconTint="@color/white" />

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <ProgressBar
            android:id="@+id/edit_job_progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/accent_indigo_light"
            android:visibility="gone" />


    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <include
        layout="@layout/drawer_menu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
