<?xml version="1.0" encoding="utf-8"?>
<!-- Speed Apply — quick-add job from shared URL with company, position, location fields -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/speed_apply_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.SpeedApplyActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include layout="@layout/background_decorative" />

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <include layout="@layout/common_header" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="100dp"
                android:clipToPadding="false"
                android:paddingBottom="24dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Section Title -->
                    <TextView
                        style="@style/SectionTitle"
                        android:shadowColor="@color/accent_indigo"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="10"
                        android:text="@string/speed_apply_job_info" />

                    <!-- Source Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:cardBackgroundColor="@color/glass_background"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/accent_indigo"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/gradient_indigo_card"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="18dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:alpha="0.85"
                                android:contentDescription="@string/job_source"
                                android:src="@drawable/ic_flash"
                                app:tint="@color/white" />

                            <TextView
                                android:id="@+id/speed_apply_TXT_source"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/montserrat_semibold"
                                android:text="@string/job_source"
                                android:textColor="@color/white"
                                android:textSize="15sp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Company input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/company_layout"
                        style="@style/GlassInput.Indigo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:startIconDrawable="@drawable/ic_business"
                        app:startIconTint="@color/accent_indigo_light">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/company_text"
                            style="@style/GlassInputEditText.Indigo"
                            android:hint="@string/speed_apply_company" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Position input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/position_layout"
                        style="@style/GlassInput.Indigo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:startIconDrawable="@drawable/ic_work"
                        app:startIconTint="@color/accent_indigo_light">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/position_text"
                            style="@style/GlassInputEditText.Indigo"
                            android:hint="@string/speed_apply_position" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Location input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/location_layout"
                        style="@style/GlassInput.Indigo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:startIconDrawable="@drawable/ic_location"
                        app:startIconTint="@color/accent_indigo_light">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/location_text"
                            style="@style/GlassInputEditText.Indigo"
                            android:hint="@string/speed_apply_location" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- URL input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/url_layout"
                        style="@style/GlassInput.Indigo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="28dp"
                        app:startIconDrawable="@drawable/ic_link"
                        app:startIconTint="@color/accent_indigo_light">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/url_text"
                            style="@style/GlassInputEditText.Indigo"
                            android:hint="@string/speed_apply_url" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <!-- Skip button -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/speed_apply_btn_skip"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/glass_background"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/accent_indigo"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:paddingHorizontal="16dp"
                                android:paddingVertical="16dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:contentDescription="@string/speed_apply_skip"
                                    android:src="@drawable/ic_close"
                                    app:tint="@color/white" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:fontFamily="@font/montserrat_semibold"
                                    android:text="@string/speed_apply_skip"
                                    android:textColor="@color/white"
                                    android:textSize="14sp" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- Save button -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/speed_apply_btn_save"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="8dp"
                            app:strokeColor="@color/accent_indigo"
                            app:strokeWidth="1.5dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/gradient_indigo_card"
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:paddingHorizontal="16dp"
                                android:paddingVertical="16dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:contentDescription="@string/speed_apply_save"
                                    android:src="@drawable/ic_save"
                                    app:tint="@color/white" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:fontFamily="@font/montserrat_semibold"
                                    android:text="@string/speed_apply_save"
                                    android:textColor="@color/white"
                                    android:textSize="14sp" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Progress bar -->
                    <ProgressBar
                        android:id="@+id/speed_apply_progress_bar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="24dp"
                        android:indeterminateTint="@color/accent_indigo"
                        android:visibility="gone"
                        tools:visibility="visible" />

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

    </FrameLayout>

    <include
        layout="@layout/drawer_menu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
