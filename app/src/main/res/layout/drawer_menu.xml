<?xml version="1.0" encoding="utf-8"?>
<!-- Navigation drawer — logo header, menu items, and logout button -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_menu_container"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:background="@color/drawer_background"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/gradient_purple_blue"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:importantForAccessibility="no"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_hunter" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/montserrat_bold"
            android:letterSpacing="0.06"
            android:shadowColor="@color/purple_glow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="12"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.75"
            android:fontFamily="@font/montserrat_medium"
            android:letterSpacing="0.03"
            android:text="@string/drawer_tagline"
            android:textColor="@color/accent_cyan"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Scrollable menu -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp"
            android:paddingTop="16dp">

            <!-- Section: MENU -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="24dp"
                android:fontFamily="@font/montserrat_bold"
                android:letterSpacing="0.18"
                android:text="@string/drawer_section_menu"
                android:textColor="@color/text_hint_white"
                android:textSize="10sp" />

            <!-- Job Tracker -->
            <LinearLayout
                android:id="@+id/drawer_menu_job_tracker"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/ripple_white_light"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="24dp"
                android:paddingStart="24dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_work"
                    app:tint="@color/accent_indigo_light" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/montserrat_semibold"
                    android:text="@string/drawer_job_tracker"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Interviews -->
            <LinearLayout
                android:id="@+id/drawer_menu_interviews"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/ripple_white_light"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="24dp"
                android:paddingStart="24dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/stat_accent_blue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/montserrat_semibold"
                    android:text="@string/drawer_interviews"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- CV Manager -->
            <LinearLayout
                android:id="@+id/drawer_menu_cv_manager"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/ripple_white_light"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="24dp"
                android:paddingStart="24dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_cv_document"
                    app:tint="@color/accent_teal_light" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/montserrat_semibold"
                    android:text="@string/drawer_cv_manager"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Community -->
            <LinearLayout
                android:id="@+id/drawer_menu_community"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/ripple_white_light"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="24dp"
                android:paddingStart="24dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_people"
                    app:tint="@color/accent_rose_light" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/montserrat_semibold"
                    android:text="@string/drawer_community"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Favorites -->
            <LinearLayout
                android:id="@+id/drawer_menu_favorites"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/ripple_white_light"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="24dp"
                android:paddingStart="24dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_favorite_border"
                    app:tint="@color/stat_accent_rose" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/montserrat_semibold"
                    android:text="@string/drawer_favorites"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="12dp"
                android:layout_marginEnd="24dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:background="@color/drawer_divider" />

            <!-- Section: MORE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="24dp"
                android:fontFamily="@font/montserrat_bold"
                android:letterSpacing="0.18"
                android:text="@string/drawer_section_more"
                android:textColor="@color/text_hint_white"
                android:textSize="10sp" />

            <!-- Statistics -->
            <LinearLayout
                android:id="@+id/drawer_menu_statistics"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/ripple_white_light"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="24dp"
                android:paddingStart="24dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_analytics"
                    app:tint="@color/stat_accent_amber" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/montserrat_semibold"
                    android:text="@string/drawer_statistics"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/drawer_menu_profile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/ripple_white_light"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="24dp"
                android:paddingStart="24dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_person"
                    app:tint="@color/primary_purple" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/montserrat_semibold"
                    android:text="@string/drawer_profile"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Settings -->
            <LinearLayout
                android:id="@+id/drawer_menu_settings"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/ripple_white_light"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="24dp"
                android:paddingStart="24dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/primary_purple" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/montserrat_semibold"
                    android:text="@string/drawer_settings"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- About -->
            <LinearLayout
                android:id="@+id/drawer_menu_about"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/ripple_white_light"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="24dp"
                android:paddingStart="24dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_info"
                    app:tint="@color/primary_purple" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/montserrat_semibold"
                    android:text="@string/drawer_about"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/drawer_divider" />

    <!-- Logout -->
    <LinearLayout
        android:id="@+id/drawer_menu_logout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ripple_red_light"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_logout"
            app:tint="@color/error" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/montserrat_semibold"
            android:text="@string/drawer_logout"
            android:textColor="@color/error"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
