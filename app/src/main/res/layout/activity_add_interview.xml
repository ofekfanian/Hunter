<?xml version="1.0" encoding="utf-8"?>
<!-- Add Interview form — company, date/time, type, reminder, and notes -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.AddInterviewActivity"
    tools:ignore="RtlHardcoded">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_dark_purple">

        <include layout="@layout/common_header" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="100dp"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Basic Information -->
                <TextView
                    style="@style/SectionTitle"
                    android:text="@string/basic_information"
                    android:shadowColor="@color/stat_accent_blue"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10"
                    />

                <com.google.android.material.card.MaterialCardView
                    style="@style/GlassCard"
                    android:layout_marginBottom="20dp"
                    app:strokeColor="@color/stat_accent_blue"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:baselineAligned="false">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Blue"
                            android:id="@+id/company_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_work"
                            app:startIconTint="@color/stat_accent_blue">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Blue"
                                android:id="@+id/company_text"
                                android:hint="@string/hint_company" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Blue"
                            android:id="@+id/position_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_work"
                            app:startIconTint="@color/stat_accent_blue">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Blue"
                                android:id="@+id/position_text"
                                android:hint="@string/hint_position" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Schedule Details -->
                <TextView
                    style="@style/SectionTitle"
                    android:text="@string/schedule_details"
                    android:shadowColor="@color/stat_accent_blue"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10"
                    />

                <com.google.android.material.card.MaterialCardView
                    style="@style/GlassCard"
                    android:layout_marginBottom="20dp"
                    app:strokeColor="@color/stat_accent_blue"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/GlassInput.Blue"
                                android:id="@+id/date_layout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:layout_marginBottom="16dp"
                                app:startIconDrawable="@drawable/ic_calendar"
                                app:startIconTint="@color/stat_accent_blue">

                                <com.google.android.material.textfield.TextInputEditText
                                    style="@style/GlassInputEditText.Blue"
                                    android:id="@+id/date_text"
                                    android:hint="@string/hint_date" />

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/GlassInput.Blue"
                                android:id="@+id/time_layout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:layout_marginBottom="16dp"
                                app:startIconDrawable="@drawable/ic_calendar"
                                app:startIconTint="@color/stat_accent_blue">

                                <com.google.android.material.textfield.TextInputEditText
                                    style="@style/GlassInputEditText.Blue"
                                    android:id="@+id/time_text"
                                    android:hint="@string/hint_time" />

                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="@string/interview_type"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/type_chip_group"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:checkedChip="@id/chip_phone"
                            app:singleSelection="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_phone"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/interview_type_phone"
                                app:chipIcon="@drawable/ic_phone"
                                app:chipIconTint="@null"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_video"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/interview_type_video"
                                app:chipIcon="@drawable/ic_videocam"
                                app:chipIconTint="@null"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_in_person"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/interview_type_in_person"
                                app:chipIcon="@drawable/ic_person"
                                app:chipIconTint="@null"
                                tools:ignore="TextContrastCheck" />
                        </com.google.android.material.chip.ChipGroup>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="@string/interview_reminder"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/reminder_chip_group"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:checkedChip="@id/chip_1hour"
                            app:singleSelection="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_30min"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/reminder_30min"
                                app:chipIcon="@drawable/ic_alarm"
                                app:chipIconTint="@null"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_1hour"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/reminder_1hour"
                                app:chipIcon="@drawable/ic_alarm"
                                app:chipIconTint="@null"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_1day"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/reminder_1day"
                                app:chipIcon="@drawable/ic_alarm"
                                app:chipIconTint="@null"
                                tools:ignore="TextContrastCheck" />
                        </com.google.android.material.chip.ChipGroup>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Additional Details -->
                <TextView
                    style="@style/SectionTitle"
                    android:text="@string/additional_details"
                    android:shadowColor="@color/stat_accent_blue"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10"
                    />

                <com.google.android.material.card.MaterialCardView
                    style="@style/GlassCard.LargeMargin"
                    app:strokeColor="@color/stat_accent_blue"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:baselineAligned="false">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Blue"
                            android:id="@+id/location_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_location"
                            app:startIconTint="@color/stat_accent_blue">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Blue"
                                android:id="@+id/location_text"
                                android:hint="@string/hint_location" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Blue"
                            android:id="@+id/interviewer_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_person"
                            app:startIconTint="@color/stat_accent_blue">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Blue"
                                android:id="@+id/interviewer_text"
                                android:hint="@string/hint_interviewer" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Blue"
                            android:id="@+id/notes_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_edit"
                            app:startIconTint="@color/stat_accent_blue">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Blue"
                                android:id="@+id/notes_text"
                                android:hint="@string/hint_notes" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/save_button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/button_gradient_blue"
                    android:drawableStart="@drawable/ic_save"
                    android:drawablePadding="12dp"
                    android:elevation="12dp"
                    android:fontFamily="@font/montserrat_bold"
                    android:gravity="center"
                    android:letterSpacing="0.05"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:text="@string/save_interview"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    tools:ignore="VisualLintButtonSize,RtlSymmetry" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <include
        layout="@layout/drawer_menu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
