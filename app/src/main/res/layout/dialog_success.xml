<?xml version="1.0" encoding="utf-8"?>
<!-- Success dialog — checkmark icon with title and message -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialog_success_card"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    app:cardBackgroundColor="@color/dialog_background"
    app:cardCornerRadius="24dp"
    app:cardElevation="10dp"
    app:strokeColor="@color/success_stroke"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Icon Circle -->
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp">

            <View
                android:id="@+id/dialog_success_circle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circle_glass_success" />

            <ImageView
                android:id="@+id/dialog_success_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/success" />

        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/dialog_success_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/montserrat_bold"
            android:shadowColor="@color/success_glow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="10"
            android:text="@string/dialog_success_title"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="22sp" />

        <!-- Message -->
        <TextView
            android:id="@+id/dialog_success_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0.7"
            android:fontFamily="@font/montserrat_medium"
            android:lineSpacingExtra="4dp"
            android:text="@string/dialog_success_message"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="13sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
