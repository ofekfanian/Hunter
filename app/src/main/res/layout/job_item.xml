<?xml version="1.0" encoding="utf-8"?>
<!-- Single job card — company logo, position, location, date, status/salary badges -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/job_CARD_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginEnd="16dp"
    android:layout_marginStart="16dp"
    android:layout_marginTop="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/glass_background"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/indigo_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Logo + Company + Position + Favorite -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Company Logo Circle -->
            <FrameLayout
                android:id="@+id/job_FRAME_logo_container"
                android:layout_width="48dp"
                android:layout_height="48dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_company_logo_elegant" />

                <TextView
                    android:id="@+id/job_TXT_company_initial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/montserrat_bold"
                    android:gravity="center"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    tools:text="G" />

            </FrameLayout>

            <!-- Company + Position -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/job_TXT_company_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/montserrat_bold"
                    android:maxLines="1"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    tools:text="Google" />

                <TextView
                    android:id="@+id/job_TXT_position"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:alpha="0.65"
                    android:ellipsize="end"
                    android:fontFamily="@font/montserrat_medium"
                    android:maxLines="1"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    tools:text="Senior Android Developer" />

            </LinearLayout>

            <!-- Favorite Button -->
            <ImageButton
                android:id="@+id/job_BTN_favorite"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/job_favorite"
                android:padding="6dp"
                android:src="@drawable/ic_favorite_border"
                app:tint="@color/accent_indigo_light" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="14dp"
            android:background="@color/drawer_divider" />

        <!-- Info Row: Location + Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Location -->
            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:contentDescription="@string/location_icon"
                android:src="@drawable/ic_location"
                app:tint="@color/accent_indigo_light" />

            <TextView
                android:id="@+id/job_TXT_location"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/montserrat_medium"
                android:maxLines="1"
                android:textColor="@color/white"
                android:textSize="12sp"
                tools:text="Tel Aviv" />

            <!-- Date -->
            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_marginStart="12dp"
                android:contentDescription="@string/date_icon"
                android:src="@drawable/ic_calendar"
                app:tint="@color/accent_indigo_light" />

            <TextView
                android:id="@+id/job_TXT_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:alpha="0.6"
                android:fontFamily="@font/montserrat_medium"
                android:textColor="@color/white"
                android:textSize="12sp"
                tools:text="2 days ago" />

        </LinearLayout>

        <!-- Badges Row: Status + Salary + CV -->
        <LinearLayout
            android:id="@+id/status_badges_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Status Badge -->
            <LinearLayout
                android:id="@+id/status_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_status_modern"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingBottom="4dp"
                android:paddingEnd="10dp"
                android:paddingStart="10dp"
                android:paddingTop="4dp">

                <View
                    android:id="@+id/job_VIEW_status_indicator"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/status_indicator"
                    tools:backgroundTint="@color/status_applied" />

                <TextView
                    android:id="@+id/job_TXT_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat_semibold"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    tools:text="Applied" />

            </LinearLayout>

            <!-- Salary Badge -->

            <!-- CV Version -->
            <TextView
                android:id="@+id/job_TXT_salary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/chip_salary"
                android:fontFamily="@font/montserrat_bold"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="@color/accent_green"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="$120K"
                tools:visibility="visible" />

            <!-- Work Model Badge -->
            <TextView
                android:id="@+id/job_TXT_work_model"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/chip_salary"
                android:fontFamily="@font/montserrat_bold"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="@color/accent_indigo_light"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="Remote"
                tools:visibility="visible" />

            <!-- Source Badge -->
            <TextView
                android:id="@+id/job_TXT_source"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/chip_cv_version"
                android:fontFamily="@font/montserrat_medium"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="@color/white"
                android:alpha="0.7"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="LinkedIn"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/cv_version_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/chip_cv_version"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="4dp"
                android:paddingEnd="8dp"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:contentDescription="@string/cv_manager"
                    android:src="@drawable/ic_cv_document"
                    app:tint="@color/accent_indigo_light" />

                <TextView
                    android:id="@+id/job_TXT_cv_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:alpha="0.7"
                    android:fontFamily="@font/montserrat_medium"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    tools:text="Tech Resume v2" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
