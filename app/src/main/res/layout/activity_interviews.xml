<?xml version="1.0" encoding="utf-8"?>
<!-- Interviews screen — stats cards, upcoming/past tabs, interview list via ViewPager2 -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.InterviewsActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_dark_purple">

        <include layout="@layout/common_header" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="100dp"
            android:clipToPadding="false"
            android:paddingBottom="80dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Overview Section Title -->
                <TextView
                    style="@style/SectionTitle"
                    android:text="@string/statistics_overview"
                    android:shadowColor="@color/stat_accent_blue"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10" />

                <!-- Statistics Cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardBackgroundColor="@color/glass_background"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/stat_accent_blue"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/gradient_stat_interviews"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginBottom="8dp"
                                android:src="@drawable/ic_calendar"
                                app:tint="@color/white"
                                android:alpha="0.85"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:id="@+id/stat_total_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="@string/count_zero"
                                android:textColor="@color/white"
                                android:textSize="36sp"
                                tools:text="12" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:alpha="0.9"
                                android:fontFamily="@font/montserrat_semibold"
                                android:text="@string/total_interviews"
                                android:textColor="@color/white"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardBackgroundColor="@color/glass_background"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/stat_accent_blue"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/gradient_stat_interviews"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginBottom="8dp"
                                android:src="@drawable/ic_upcoming"
                                app:tint="@color/white"
                                android:alpha="0.85"
                                android:importantForAccessibility="no" />

                            <TextView
                                android:id="@+id/stat_upcoming_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="@string/count_zero"
                                android:textColor="@color/white"
                                android:textSize="36sp"
                                tools:text="3" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:alpha="0.9"
                                android:fontFamily="@font/montserrat_semibold"
                                android:text="@string/upcoming_interviews"
                                android:textColor="@color/white"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Interviews Section Title -->
                <TextView
                    style="@style/SectionTitle"
                    android:text="@string/interviews_title"
                    android:shadowColor="@color/stat_accent_blue"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10" />

                <!-- Tabs -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/glass_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/stat_accent_blue"
                    app:strokeWidth="1.5dp">

                    <com.google.android.material.tabs.TabLayout
                        android:id="@+id/tabs"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="@drawable/gradient_stat_interviews"
                        app:tabIndicatorColor="@color/white"
                        app:tabIndicatorFullWidth="false"
                        app:tabIndicatorHeight="3dp"
                        app:tabSelectedTextColor="@color/white"
                        app:tabTextColor="@color/tab_text_unselected"
                        app:tabTextAppearance="@style/TabTextStyle">

                        <com.google.android.material.tabs.TabItem
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/upcoming_interviews" />

                        <com.google.android.material.tabs.TabItem
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tab_past" />

                    </com.google.android.material.tabs.TabLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Interview List (ViewPager2) -->
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/view_pager"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- FAB -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab_add_interview"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="110dp"
            android:background="@drawable/button_gradient_blue"
            android:fontFamily="@font/montserrat_bold"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:stateListAnimator="@null"
            android:text="@string/add_interview"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:backgroundTint="@null"
            app:cornerRadius="32dp"
            app:icon="@drawable/ic_add"
            app:iconTint="@color/white" />

        <include layout="@layout/bottom_navigation" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <include
        layout="@layout/drawer_menu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
