<?xml version="1.0" encoding="utf-8"?>
<!-- Single onboarding page — glass circle icon, title, and description -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Glass circle with icon -->
    <FrameLayout
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginBottom="40dp">

        <View
            android:id="@+id/onboarding_circle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_glass" />

        <ImageView
            android:id="@+id/onboarding_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/onboarding_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_bold"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="28sp" />

    <!-- Description -->
    <TextView
        android:id="@+id/onboarding_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        android:alpha="0.85"
        android:fontFamily="@font/montserrat_medium"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:textColor="@color/white"
        android:textSize="16sp" />

</LinearLayout>
