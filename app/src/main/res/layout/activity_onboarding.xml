<?xml version="1.0" encoding="utf-8"?>
<!-- Onboarding — ViewPager2 with dot indicators, skip and next buttons -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Decorative background -->
    <include layout="@layout/background_decorative" />

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/onboarding_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <!-- ViewPager2 (behind everything) -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/onboarding_view_pager"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/onboarding_dots_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Skip button (on top of ViewPager, top right) -->
        <TextView
            android:id="@+id/onboarding_btn_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:elevation="10dp"
            android:fontFamily="@font/montserrat_semibold"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="@string/onboarding_skip"
            android:textColor="#B0FFFFFF"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Dot indicators -->
        <LinearLayout
            android:id="@+id/onboarding_dots_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@id/onboarding_btn_next"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/dot_0"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginHorizontal="6dp"
                android:importantForAccessibility="no"
                android:src="@drawable/dot_active" />

            <ImageView
                android:id="@+id/dot_1"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginHorizontal="6dp"
                android:importantForAccessibility="no"
                android:src="@drawable/dot_inactive" />

            <ImageView
                android:id="@+id/dot_2"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginHorizontal="6dp"
                android:importantForAccessibility="no"
                android:src="@drawable/dot_inactive" />
        </LinearLayout>

        <!-- Next / Get Started button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/onboarding_btn_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="10dp"
            app:strokeColor="@color/main_card_stroke_indigo"
            app:strokeWidth="1.5dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/onboarding_btn_next_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gradient_main_jobs"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:paddingVertical="16dp"
                android:text="@string/onboarding_next"
                android:textColor="@color/white"
                android:textSize="16sp" />
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
