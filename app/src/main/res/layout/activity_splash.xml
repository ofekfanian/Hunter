<?xml version="1.0" encoding="utf-8"?>
<!-- Splash screen — animated logo with glow rings, particles, title, and loading dots -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.SplashActivity">

    <!-- Decorative background -->
    <include layout="@layout/background_decorative" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ===== Outer Glow Ring ===== -->
        <View
            android:id="@+id/splash_ring_outer"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:background="@drawable/splash_ring_outer"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0.35" />

        <!-- ===== Middle Ring ===== -->
        <View
            android:id="@+id/splash_ring_middle"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:background="@drawable/splash_ring_middle"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="@id/splash_ring_outer"
            app:layout_constraintEnd_toEndOf="@id/splash_ring_outer"
            app:layout_constraintTop_toTopOf="@id/splash_ring_outer"
            app:layout_constraintBottom_toBottomOf="@id/splash_ring_outer" />

        <!-- ===== Glass Circle Behind Logo ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/splash_glass_circle"
            android:layout_width="200dp"
            android:layout_height="200dp"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="100dp"
            app:cardElevation="24dp"
            app:strokeColor="#33FFFFFF"
            app:strokeWidth="2dp"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="@id/splash_ring_outer"
            app:layout_constraintEnd_toEndOf="@id/splash_ring_outer"
            app:layout_constraintTop_toTopOf="@id/splash_ring_outer"
            app:layout_constraintBottom_toBottomOf="@id/splash_ring_outer">

            <!-- Logo -->
            <ImageView
                android:id="@+id/splash_IMG_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="28dp"
                android:src="@drawable/logo_hunter"
                android:scaleType="fitCenter"
                android:contentDescription="@string/app_name" />

        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Floating Particles ===== -->
        <View
            android:id="@+id/splash_particle_1"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/splash_particle"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/splash_ring_outer"
            app:layout_constraintHorizontal_bias="0.15"
            app:layout_constraintVertical_bias="0.2"
            app:layout_constraintBottom_toBottomOf="@id/splash_ring_outer" />

        <View
            android:id="@+id/splash_particle_2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/splash_particle_cyan"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/splash_ring_outer"
            app:layout_constraintHorizontal_bias="0.85"
            app:layout_constraintVertical_bias="0.15"
            app:layout_constraintBottom_toBottomOf="@id/splash_ring_outer" />

        <View
            android:id="@+id/splash_particle_3"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/splash_particle"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/splash_ring_outer"
            app:layout_constraintHorizontal_bias="0.9"
            app:layout_constraintVertical_bias="0.8"
            app:layout_constraintBottom_toBottomOf="@id/splash_ring_outer" />

        <View
            android:id="@+id/splash_particle_4"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/splash_particle_cyan"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/splash_ring_outer"
            app:layout_constraintHorizontal_bias="0.1"
            app:layout_constraintVertical_bias="0.75"
            app:layout_constraintBottom_toBottomOf="@id/splash_ring_outer" />

        <!-- ===== App Title ===== -->
        <TextView
            android:id="@+id/splash_TXT_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="52sp"
            android:fontFamily="@font/montserrat_bold"
            android:letterSpacing="0.12"
            android:shadowColor="#80667EEA"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="30"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/splash_ring_outer" />

        <!-- ===== Tagline ===== -->
        <TextView
            android:id="@+id/splash_TXT_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/splash_tagline"
            android:textColor="@color/accent_cyan"
            android:textSize="17sp"
            android:fontFamily="@font/montserrat_medium"
            android:letterSpacing="0.06"
            android:shadowColor="#6000F2FE"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="15"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/splash_TXT_app_name" />

        <!-- ===== Decorative Line ===== -->
        <View
            android:id="@+id/splash_line"
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/splash_decorative_line"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/splash_TXT_tagline" />

        <!-- ===== Loading Dots ===== -->
        <LinearLayout
            android:id="@+id/splash_loading_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="80dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:alpha="0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/splash_TXT_version">

            <View
                android:id="@+id/splash_dot_1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/splash_loading_dot" />

            <View
                android:id="@+id/splash_dot_2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/splash_loading_dot" />

            <View
                android:id="@+id/splash_dot_3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/splash_loading_dot" />

        </LinearLayout>

        <!-- ===== Version ===== -->
        <TextView
            android:id="@+id/splash_TXT_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="@string/splash_version"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:fontFamily="@font/montserrat_medium"
            android:letterSpacing="0.15"
            android:alpha="0.4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
