<?xml version="1.0" encoding="utf-8"?>
<!-- Floating bottom navigation bar — Jobs, Statistics, CV, Profile tabs -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottom_navigation_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="14dp"
    app:cardCornerRadius="28dp"
    app:cardElevation="16dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/nav_stroke"
    app:cardBackgroundColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_purple_blue"
        android:orientation="horizontal"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:gravity="center">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/nav_home_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_home"
                app:tint="@color/white"
                android:alpha="0.85"
                android:importantForAccessibility="no" />
            <TextView
                android:id="@+id/nav_home_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_jobs"
                android:textColor="@color/white"
                android:alpha="0"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_semibold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_statistics"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/nav_statistics_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_statistics"
                app:tint="@color/white"
                android:alpha="0.85"
                android:importantForAccessibility="no" />
            <TextView
                android:id="@+id/nav_statistics_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_statistics"
                android:textColor="@color/white"
                android:alpha="0"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_semibold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_cv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/nav_cv_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_folder_special"
                app:tint="@color/white"
                android:alpha="0.85"
                android:importantForAccessibility="no" />
            <TextView
                android:id="@+id/nav_cv_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_cv"
                android:textColor="@color/white"
                android:alpha="0"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_semibold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/nav_profile_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_person"
                app:tint="@color/white"
                android:alpha="0.85"
                android:importantForAccessibility="no" />
            <TextView
                android:id="@+id/nav_profile_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_profile"
                android:textColor="@color/white"
                android:alpha="0"
                android:textSize="10sp"
                android:fontFamily="@font/montserrat_semibold" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
