<?xml version="1.0" encoding="utf-8"?>
<!-- Add Job form — company, position, status chips, and notes -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.AddJobActivity"
    tools:ignore="RtlHardcoded">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_dark_purple">

        <include layout="@layout/common_header" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="100dp"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Basic Information -->
                <TextView
                    android:id="@+id/title_basic_info"
                    style="@style/SectionTitle"
                    android:text="@string/basic_information"
                    android:shadowColor="@color/accent_indigo_light"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10"
                    />

                <com.google.android.material.card.MaterialCardView
                    style="@style/GlassCard"
                    android:layout_marginBottom="20dp"
                    app:strokeColor="@color/accent_indigo_light"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:baselineAligned="false">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/company_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_work"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/company_text"
                                android:hint="@string/hint_company" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/position_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_work"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/position_text"
                                android:hint="@string/hint_position" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Job Details -->
                <TextView
                    android:id="@+id/title_job_details"
                    style="@style/SectionTitle"
                    android:text="@string/job_details"
                    android:shadowColor="@color/accent_indigo_light"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10"
                    />

                <com.google.android.material.card.MaterialCardView
                    style="@style/GlassCard"
                    android:layout_marginBottom="20dp"
                    app:strokeColor="@color/accent_indigo_light"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:baselineAligned="false">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/location_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_location"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/location_text"
                                android:hint="@string/hint_location" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/salary_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_work"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/salary_text"
                                android:hint="@string/hint_salary" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/job_url_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_link"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/job_url_text"
                                android:hint="@string/hint_job_url" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/contact_name_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_person"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/contact_name_text"
                                android:hint="@string/hint_contact_name" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Source Chips -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="8dp"
                            android:text="@string/job_source"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:fontFamily="@font/montserrat_bold" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/source_chip_group"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:singleSelection="false">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_linkedin"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/source_linkedin"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_indeed"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/source_indeed"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_drushim"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/source_drushim"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_alljobs"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/source_alljobs"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_referral"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/source_referral"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_other_source"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/source_other"
                                tools:ignore="TextContrastCheck" />

                        </com.google.android.material.chip.ChipGroup>

                        <!-- Work Model Chips -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="8dp"
                            android:text="@string/hint_work_model"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:fontFamily="@font/montserrat_bold" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/work_model_chip_group"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:singleSelection="false">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_onsite"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/work_model_onsite"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_hybrid"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/work_model_hybrid"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_remote"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/work_model_remote"
                                tools:ignore="TextContrastCheck" />

                        </com.google.android.material.chip.ChipGroup>

                        <!-- Status Chips -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="8dp"
                            android:text="@string/job_status"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:fontFamily="@font/montserrat_bold" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/status_chip_group"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:checkedChip="@id/chip_applied">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_applied"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/status_applied"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_screening"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/status_screening"
                                tools:ignore="TextContrastCheck" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_interview"
                                style="@style/AppChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/status_interview"
                                tools:ignore="TextContrastCheck" />
                        </com.google.android.material.chip.ChipGroup>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Additional Info -->
                <TextView
                    android:id="@+id/title_additional"
                    style="@style/SectionTitle"
                    android:text="@string/additional_details"
                    android:shadowColor="@color/accent_indigo_light"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10"
                    />

                <com.google.android.material.card.MaterialCardView
                    style="@style/GlassCard.LargeMargin"
                    app:strokeColor="@color/accent_indigo_light"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:baselineAligned="false">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/cv_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_work"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/cv_text"
                                android:hint="@string/hint_cv_version" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/GlassInput.Indigo"
                            android:id="@+id/notes_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:startIconDrawable="@drawable/ic_edit"
                            app:startIconTint="@color/accent_indigo_light">

                            <com.google.android.material.textfield.TextInputEditText
                                style="@style/GlassInputEditText.Indigo"
                                android:id="@+id/notes_text"
                                android:hint="@string/hint_notes" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Save Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/save_button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/save_job"
                    android:textSize="17sp"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:fontFamily="@font/montserrat_bold"
                    android:textColor="@color/white"
                    android:letterSpacing="0.05"
                    android:elevation="12dp"
                    android:stateListAnimator="@null"
                    android:background="@drawable/button_gradient_premium"
                    android:drawableStart="@drawable/ic_save"
                    android:drawableTint="@color/white"
                    android:drawablePadding="12dp"
                    android:gravity="center"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    tools:ignore="VisualLintButtonSize,RtlSymmetry" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Drawer Menu -->
    <include
        layout="@layout/drawer_menu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
