<?xml version="1.0" encoding="utf-8"?>
<!-- Community screen — hosts question list fragment with add-question FAB -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.CommunityActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_dark_purple">

        <include layout="@layout/common_header" />

        <FrameLayout
            android:id="@+id/community_fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="100dp"
            tools:layout="@layout/fragment_community_question_list" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/community_FAB_add"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="110dp"
            android:background="@drawable/button_gradient_rose"
            android:fontFamily="@font/montserrat_bold"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:stateListAnimator="@null"
            android:text="@string/add_question"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:backgroundTint="@null"
            app:cornerRadius="32dp"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/white" />

        <include layout="@layout/bottom_navigation" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <include
        layout="@layout/drawer_menu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
